# ── DEWDROP configuration ─────────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Storage (defaults to ./data/dewdrop.sqlite3 if unset)
# DEWDROP_DB_PATH=/opt/dewdrop/data/dewdrop.sqlite3

# ── Location being forecast (defaults to Kansas City Intl / MCI) ──────────
DEWDROP_LOCATION_NAME=kansas_city
DEWDROP_LATITUDE=39.2976
DEWDROP_LONGITUDE=-94.7139
DEWDROP_TIMEZONE=America/Chicago
# How many days out to snapshot (today=0 .. today+N).
DEWDROP_HORIZON_DAYS=10

# ── Forecast sources (comma-separated). Keyless ones work immediately. ────
# Known: open_meteo, nws, openweathermap, tomorrow_io, weatherbit, wunderground
DEWDROP_ENABLED_SOURCES=open_meteo,nws

# Forecast API keys (only needed for the keyed sources you enable)
OPENWEATHERMAP_API_KEY=
TOMORROW_IO_API_KEY=
WEATHERBIT_API_KEY=
WUNDERGROUND_API_KEY=

# ── Actuals / ground truth (comma-separated). ASOS is primary. ────────────
# Known: asos_mci, ecowitt_local
DEWDROP_ENABLED_ACTUALS=asos_mci

# NOAA ASOS via Iowa Environmental Mesonet (keyless). MCI is in network MO_ASOS.
DEWDROP_ASOS_STATION=MCI
DEWDROP_ASOS_NETWORK=MO_ASOS

# EcoWitt GW2000 — local gateway IP (live data only) ...
DEWDROP_GW2000_HOST=
# ... and cloud credentials (needed for daily high/low/precip history).
ECOWITT_APP_KEY=
ECOWITT_API_KEY=
ECOWITT_MAC=

# ── Read-only HTTP API + web UI (also queried by Berries) ─────────────────
DEWDROP_API_HOST=127.0.0.1
DEWDROP_API_PORT=8003
